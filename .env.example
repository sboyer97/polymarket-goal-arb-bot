# =========================================================
# Polymarket credentials (CLOB trading)
# Option A: EOA + pre-generated API creds (API_KEY/SECRET/PASSPHRASE + PRIVATE_KEY)
# Option B: Magic / Smart Wallet — leave API_KEY/SECRET/PASSPHRASE empty,
#           set POLYMARKET_SMART_WALLET (profile address) + PRIVATE_KEY (creds derived)
# =========================================================
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=your_wallet_private_key
POLYMARKET_SMART_WALLET=your_polymarket_profile_address
POLYMARKET_CHAIN_ID=137

# =========================================================
# Live goal-detection data providers (pick one or more)
# =========================================================
# Sportmonks — https://www.sportmonks.com
SPORTMONKS_API_TOKEN=your_sportmonks_api_token

# TheSports WebSocket — https://mq.thesports.com
THESPORTS_WS_URL=wss://mq.thesports.com
THESPORTS_USER=your_thesports_user
THESPORTS_SECRET=your_thesports_secret
THESPORTS_TOPIC=your_thesports_topic
THESPORTS_API_SCHEDULE_URL=

# AllSportsAPI — https://allsportsapi.com
DATA_PROVIDER_TYPE=allsportsapi
DATA_PROVIDER_API_KEY=your_allsportsapi_key

# =========================================================
# Trading parameters
# =========================================================
TRADING_BET_AMOUNT_USDC=5
MAX_POSITION_SIZE=100
MIN_EDGE_PERCENT=2.0
EXIT_AFTER_SECONDS=60
TAKE_PROFIT_PCT=5.0
STOP_LOSS_PCT=-5.0
MIN_MINUTE_TO_BET=0
MIN_LIQUIDITY_USD=50.0
DRY_RUN=true

# =========================================================
# Logging / notifications (optional)
# =========================================================
LOG_LEVEL=INFO
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFICATIONS_ENABLED=false
